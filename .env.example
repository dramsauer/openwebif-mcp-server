# OpenWebif base URL of your Vu+/Enigma2 receiver.
OPENWEBIF_BASE_URL=http://192.168.178.50

# Optional, only needed when OpenWebif HTTP authentication is enabled.
OPENWEBIF_USERNAME=
OPENWEBIF_PASSWORD=

# Keep false for a discovery/read-only setup. Set true to allow timers, zap,
# messages, remote-control keys, and other receiver-changing actions.
OPENWEBIF_ALLOW_MUTATIONS=false

# MCP HTTP bind settings inside the container.
MCP_HOST=0.0.0.0
MCP_PORT=8000

# DNS-rebinding protection. Leave empty on a trusted LAN. To re-enable
# protection, list the exact Host headers clients use (comma-separated),
# e.g. MCP_ALLOWED_HOSTS=mcp.example.com,192.168.178.50:8000
# Any Host not in this list is rejected with HTTP 421.
MCP_ALLOWED_HOSTS=

# HTTP timeout in seconds for calls from the MCP server to OpenWebif.
OPENWEBIF_TIMEOUT=10

